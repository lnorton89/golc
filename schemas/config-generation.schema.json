{
  "$comment": "GENERATED by github.com/lnorton89/golc/internal/contracts. DO NOT EDIT. Schema: config-generation.",
  "$id": "https://github.com/lnorton89/golc/internal/contracts/generation-schema",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "generation": {
      "additionalProperties": false,
      "properties": {
        "line_endings": {
          "description": "Normalized generated-file line ending; D-08 requires byte-stable LF.",
          "enum": [
            "lf"
          ],
          "type": "string"
        },
        "schemas_dir": {
          "description": "Repository-relative directory committed generated schemas live under.",
          "pattern": "^[A-Za-z0-9._-]+(/[A-Za-z0-9._-]+)*$",
          "type": "string"
        }
      },
      "required": [
        "schemas_dir",
        "line_endings"
      ],
      "type": "object"
    },
    "schema_version": {
      "description": "Supported concern schema version.",
      "enum": [
        1
      ],
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "generation"
  ],
  "type": "object"
}
